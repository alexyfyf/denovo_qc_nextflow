/*
 * Simple Nextflow configuration
 * No nf-core complexity - just basic settings
 */

// Enable DSL2
nextflow.enable.dsl = 2

manifest {
    name            = 'alexyfyf/denovo_qc_nextflow'
    author          = 'Feng Yan'
    homePage        = 'https://github.com/alexyfyf/denovo_qc_nextflow'
    description     = 'A Nextflow pipeline for quality control and quantification of de novo transcriptome assemblies.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=21.10.3'
    version         = '1.0.0'
}

// Default parameters
params {
    // Required inputs
    assembly = null
    reference_fasta = null
    reference_gtf = null
    reference_genome = null
    busco_lineage = null
    
    // Analysis options
    input_type = 'hybrid'  // 'short', 'long', 'hybrid', 'assembly_only'
    single_end = true
    stranded = false
    
    // Optional read files (for merged quantification)
    short_reads = null
    short_reads2 = null  // For paired-end merged quantification
    long_reads = null
    
    // Sample lists for individual quantification
    short_list = null  // Text file with list of short read files
    long_list = null   // Text file with list of long read files
    short_suffix1 = "_hybrid_sub_1.fastq.gz"
    short_suffix2 = "_hybrid_sub_2.fastq.gz"
    long_suffix = "_hybrid_LR.fq.gz"
    short_rep = 12
    long_rep = 12
    
    // Output
    outdir = 'results'
    
    // Your existing conda environments
    transrate_env = '/stornext/Bioinf/data/lab_davidson/yan.a/conda_env/transrate'
    busco_env = '/stornext/Bioinf/data/lab_davidson/yan.a/conda_env/busco'
    sqanti_env = '/stornext/Bioinf/data/lab_davidson/yan.a/conda_env/squanti3'
    isoncorrect_env = '/stornext/Bioinf/data/lab_davidson/yan.a/conda_env/isoncorrect'
    
    // Tool paths (update these to your actual paths)
    sqanti_path = '/vast/projects/lab_davidson/yan.a/pea_fastq_merged/SQANTI3-5.1.2/'
    cupcake_path = '$HOME/yan.a/software/cDNA_Cupcake/'
    seqtk_path = '~/yan.a/software/seqtk/seqtk'
    corset_path = '~/yan.a/software/corset-1.09-linux64/corset'
    
    // Resources
    cpus = 48
    memory = '192.GB'
    time = '48.h'
}

// Process configuration
process {
    // Default resources
    cpus = params.cpus
    memory = params.memory
    time = params.time
    
    // Use bash shell
    shell = ['/bin/bash', '-euo', 'pipefail']
    
    // Process-specific settings
    withName: 'REFORMAT_SEQUENCES' {
        cpus = 1
        memory = '4.GB'
        time = '1.h'
    }
    
    withName: 'TRANSRATE' {
        cpus = params.cpus
        memory = '128.GB'
        time = '12.h'
    }
    
    withName: 'BUSCO' {
        cpus = params.cpus
        memory = '64.GB'
        time = '12.h'
    }
    
    withName: 'SQANTI3' {
        cpus = params.cpus
        memory = '64.GB'
        time = '24.h'
    }
    
    withName: 'BUSCO_CORRECTED' {
        cpus = params.cpus
        memory = '64.GB'
        time = '12.h'
    }
    
    withName: 'SHORT_READ_QUANT' {
        cpus = params.cpus
        memory = '64.GB'
        time = '24.h'
    }
    
    withName: 'LONG_READ_QUANT' {
        cpus = params.cpus
        memory = '64.GB'
        time = '24.h'
    }
    
    withName: 'CORSET' {
        cpus = params.cpus
        memory = '64.GB'
        time = '48.h'
    }
    
    withName: 'INDIVIDUAL_SHORT_QUANT' {
        cpus = params.cpus
        memory = '64.GB'
        time = '8.h'
    }
    
    withName: 'INDIVIDUAL_LONG_QUANT' {
        cpus = params.cpus
        memory = '64.GB'
        time = '8.h'
    }
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }
    
    slurm {
        process {
            executor = 'slurm'
        }
    }
}

// Timeline and reports
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/pipeline_dag.html"
}