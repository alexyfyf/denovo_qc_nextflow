/*
 * Example configuration for pea transcriptome analysis
 * Based on your original script parameters
 * Now includes individual sample quantification
 */

params {
    // Pipeline configuration
    input_type = 'long'
    single_end = false  // Based on original script using single reads
    stranded = false   // Original script handles unstranded data
    
    // Input files
    assembly = '/vast/projects/davidson_longread/yan.a/simulation_20240501/simulation_1m/rnabloom2/ONT_merged/rnabloom.transcripts.fa'
    
    // For merged quantification (optional)
    long_reads = '/vast/projects/davidson_longread/yan.a/simulation_20240501/sqanti_sim/1m/ONT_merged.fq'
    
    // For individual sample quantification (from your original script)
    long_list = '/vast/projects/davidson_longread/yan.a/simulation_20240501/simulation_1m/raw_reads.txt'
    
    // File naming patterns (from your original script)
    long_suffix = "/ONT_simulated.fastq"
    long_rep = 6
    
    // long read input_type
    long_read_tech = 'ont' 
    
    // Reference files
    reference_fasta = '/vast/projects/davidson_longread/yan.a/simulation_20240501/sqanti_sim/gencode.v44.subset.fasta'
    reference_gtf = '/vast/projects/davidson_longread/yan.a/simulation_20240501/sqanti_sim/gencode.v44.subset.gtf'
    reference_genome = '/vast/projects/lab_davidson/yan.a/ref/gencode/GRCh38.primary_assembly.genome.fa'
    busco_lineage = '/home/users/allstaff/yan.a/lab_davidson/yan.a/dRNA/rattle/busco_downloads/lineages/primates_odb10'
    
    // Output directory
    outdir = 'results_sim_rnabloom2'

    // Tool paths
    sqanti_path = '/vast/projects/davidson_longread/yan.a/simulation_20240501/SQANTI3-5.1.2/'
    
    // Resources (matching your original script)
    cpus = 48
    memory = '192.GB'
    time = '48.h'
}

// Use this config with:
// nextflow run main.nf -c sim_rnaspades.config -profile slurm