/*
 * Example configuration for pea transcriptome analysis
 * Based on your original script parameters
 * Now includes individual sample quantification
 */

params {
    // Pipeline configuration
    input_type = 'long'
    stranded = true   // Original script handles unstranded data
    
    // Input files
    assembly = '/home/users/allstaff/yan.a/vast_scratch/pb/5m_stranded/rnabloom2/PB_merged/rnabloom.transcripts.fa'
    
    // For merged quantification (optional)
    long_reads = '/vast/scratch/users/yan.a/vast_scratch/pb/new_download/PBMC_15M.fastq'
    
    // For individual sample quantification (from your original script)
    long_list = '/home/users/allstaff/yan.a/vast_scratch/pb/5m_stranded/raw_reads.txt'
    
    // File naming patterns (from your original script)
    long_suffix = "_5M.fasta"
    long_rep = 3
    
    // long read input_type
    long_read_tech = 'hifi' 
    
    // Reference files
    reference_fasta = '/vast/projects/lab_davidson/yan.a/ref/gencode/gencode.v44.transcripts.fa'
    reference_gtf = '/vast/projects/lab_davidson/yan.a/ref/gencode/gencode.v44.annotation.gtf'
    reference_genome = '/vast/projects/lab_davidson/yan.a/ref/gencode/GRCh38.primary_assembly.genome.fa'
    busco_lineage = '/home/users/allstaff/yan.a/lab_davidson/yan.a/dRNA/rattle/busco_downloads/lineages/primates_odb10'
    
    // Output directory
    outdir = 'results_pb_rnabloom2'

    // Tool paths
    sqanti_path = '/vast/projects/lab_davidson/yan.a/dRNA/SQANTI3-5.1.2/'
    
    // Resources (matching your original script)
    cpus = 48
    memory = '192.GB'
    time = '48.h'
}
